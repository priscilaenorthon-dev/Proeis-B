# ─────────────────────────────────────────────
#  Renomeie este arquivo para .env
#  e preencha com suas credenciais pessoais
# ─────────────────────────────────────────────

# Seu numero de matricula no PROEIS
PROEIS_LOGIN=SEU_LOGIN_AQUI

# Sua senha do PROEIS
PROEIS_PASSWORD=SUA_SENHA_AQUI

# Sua chave da API do 2captcha (crie conta em 2captcha.com)
TWOCAPTCHA_API_KEY=SUA_CHAVE_2CAPTCHA_AQUI

# Configuracoes de rede (nao precisa alterar)
PROEIS_HTTP_ATTEMPTS=2
PROEIS_CONNECT_TIMEOUT=6
PROEIS_READ_TIMEOUT=18

# Captcha 2captcha
TWOCAPTCHA_INITIAL_WAIT=6
TWOCAPTCHA_POLL_INTERVAL=1.5
TWOCAPTCHA_MAX_WAIT=120
TWOCAPTCHA_INVALID_RETRIES=5
TWOCAPTCHA_SUBMIT_TIMEOUT=45
TWOCAPTCHA_RESULT_TIMEOUT=30
